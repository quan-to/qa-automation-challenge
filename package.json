{
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^11.5.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.1.3",
    "cucumber": "^6.0.7",
    "cypress": "^10.3.1",
    "cypress-multi-reporters": "^1.6.1",
    "mocha": "^10.0.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.2.1",
    "mochawesome-report-generator": "^6.2.0",
    "move-file-cli": "^3.0.0",
    "rimraf": "^3.0.2"
  },
  "scripts": {
    "cy:open": "cypress open",
    "cy:clean": "rimraf ./cypress/results",
    "cy:run": "cypress run --browser chrome --headless --reporter cypress-multi-reporters",
    "report:merge": "npx mochawesome-merge ./cypress/results/json/*.json -o ./cypress/results/merged-report.json",
    "report:generate": "marge --save-html -o ./cypress/results ./cypress/results/merged-report.json",
    "report:format": "move-file ./cypress/results/cypress/results/merged-report.html ./cypress/results/merged-report.html",
    "report:clean": "rimraf ./cypress/results/cypress",
    "project:run": "npm run cy:clean && npm run cy:run && npm run report:merge && npm run report:generate && npm run report:format  && npm run report:clean"
  }
}
